# ============================================================
# CampusAI — .gitignore
# ============================================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
/playwright-report
/test-results

# Next.js
/.next/
/out/

# Production
/build

# Miscellaneous
.DS_Store
*.pem
Thumbs.db

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
# NOTE: .env.example IS committed — it contains key names only (no real values)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Editor
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
desktop.ini

# NOTE: prisma/migrations IS intentionally committed (do NOT add it here)
