// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== Authentication ==========

enum UserRole {
  STUDENT
  FACULTY
  HOD
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

/// Unified authentication model for all roles (Student, Faculty, HOD, Admin).
model User {
  id                  String     @id @default(cuid())
  name                String?
  email               String     @unique
  /// @deprecated no longer used for auth now that Google OAuth is the sole sign-in method.
  passwordHash        String?
  role                UserRole
  status              UserStatus @default(ACTIVE)
  isActive            Boolean    @default(true)
  emailVerified       DateTime?
  image               String?
  lastLoginAt         DateTime?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  deletedAt           DateTime?

  // Relations
  sessions          Session[]
  accounts          Account[]
  permissions       UserPermission[]
  auditLogs         ActivityLog[]
  loginHistory      LoginHistory[]
  discussionReplies DiscussionReply[]

  // Role profiles (1:1 relations)
  student Student?
  faculty Faculty?
  hod     HOD?
  admin   Admin?

  // One-to-many collections
  aiChatHistories   AIChatHistory[]
  notifications     Notification[]   @relation("UserNotifications")
  sentNotifications Notification[]   @relation("SentNotifications")
  discussions       Discussion[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  group       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([group])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean @default(true)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String?
  email         String
  success       Boolean
  ipAddress     String?
  userAgent     String?
  failureReason String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@map("login_history")
}

model ActivityLog {
  id           String   @id @default(cuid())
  userId       String
  targetUserId String?
  action       String
  details      Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==================== B1. Role Profiles ====================

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Student {
  id           String   @id @default(cuid())
  userId       String   @unique
  enrollmentNo String   @unique
  departmentId String
  semester     Int
  section      String
  cgpa         Float?
  batchYear    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])

  attendances  Attendance[]
  submissions  Submission[]
  attempts     QuizAttempt[]
  resume       Resume?
  applications Application[]
  placementProfile StudentPlacementProfile?
  dsaProgress      StudentProblemProgress[]

  @@index([departmentId])
  @@map("students")
}

model Faculty {
  id             String   @id @default(cuid())
  userId         String   @unique
  employeeId     String   @unique
  departmentId   String
  designation    String
  specialization String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department    @relation(fields: [departmentId], references: [id])

  subjects       Subject[]
  assignments    Assignment[]
  timetableSlots TimetableSlot[]

  @@index([departmentId])
  @@map("faculty")
}

model HOD {
  id           String   @id @default(cuid())
  userId       String   @unique
  departmentId String   @unique
  office       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("hods")
}

model Admin {
  id        String    @id @default(cuid())
  userId    String    @unique
  adminRole AdminRole
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ==================== B2. Academic Structure ====================

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students          Student[]
  faculty           Faculty[]
  hod               HOD?
  courses           Course[]
  academicCalendars AcademicCalendar[]
  timetables        Timetable[]

  @@map("departments")
}

model Course {
  id           String   @id @default(cuid())
  name         String
  credits      Int
  semester     Int
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subjects   Subject[]

  @@index([departmentId])
  @@map("courses")
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  courseId  String
  facultyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  faculty Faculty? @relation(fields: [facultyId], references: [id], onDelete: SetNull)

  attendances    Attendance[]
  modules        Module[]
  assignments    Assignment[]
  quizzes        Quiz[]
  discussions    Discussion[]
  timetableSlots TimetableSlot[]

  @@index([courseId])
  @@index([facultyId])
  @@map("subjects")
}

enum ClassroomType {
  LECTURE_HALL
  LAB
  SEMINAR_ROOM
}

model Classroom {
  id             String          @id @default(cuid())
  roomNumber     String          @unique
  capacity       Int
  type           ClassroomType
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  timetableSlots TimetableSlot[]

  @@map("classrooms")
}

enum AcademicEventType {
  HOLIDAY
  EXAM
  REGISTRATION
  ORIENTATION
  RESULT
  OTHER
  EVENT
}

enum SemesterTerm {
  ODD
  EVEN
}

enum SemesterStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

model Semester {
  id           String         @id @default(cuid())
  name         String
  academicYear String
  term         SemesterTerm
  startDate    DateTime
  endDate      DateTime
  status       SemesterStatus @default(UPCOMING)
  isCurrent    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  academicCalendars AcademicCalendar[]

  @@index([status])
  @@index([isCurrent])
  @@map("semesters")
}

model AcademicCalendar {
  id           String            @id @default(cuid())
  title        String
  description  String?
  eventType    AcademicEventType
  startDate    DateTime
  endDate      DateTime?
  isPublished  Boolean           @default(false)
  semesterId   String?
  departmentId String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  semester   Semester?   @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([semesterId])
  @@index([departmentId])
  @@map("academic_calendar")
}

// ==================== B3. Attendance ====================

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  subjectId   String
  date        DateTime
  status      AttendanceStatus
  markedById  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([subjectId])
  @@map("attendances")
}

// ==================== B4. LMS ====================

model Module {
  id        String   @id @default(cuid())
  title     String
  subjectId String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subject   Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  resources LearningResource[]

  @@index([subjectId])
  @@map("modules")
}

enum ResourceType {
  PDF
  VIDEO
  LINK
  DOCUMENT
}

model LearningResource {
  id        String       @id @default(cuid())
  title     String
  type      ResourceType
  fileUrl   String
  moduleId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("learning_resources")
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String
  dueDate     DateTime
  subjectId   String
  facultyId   String
  maxMarks    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  faculty Faculty @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  submissions Submission[]

  @@index([subjectId])
  @@index([facultyId])
  @@map("assignments")
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  LATE
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  studentId    String
  submittedAt  DateTime         @default(now())
  fileUrl      String
  marks        Float?
  feedback     String?
  status       SubmissionStatus
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([studentId])
  @@map("submissions")
}

model QuizQuestion {
  id                 String       @id @default(cuid())
  quizId             String
  text               String
  options            String[]
  correctOptionIndex Int

  quiz               Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers            QuizAnswer[]

  @@index([quizId])
  @@map("quiz_questions")
}

model Quiz {
  id              String         @id @default(cuid())
  title           String
  subjectId       String
  totalMarks      Int
  durationMinutes Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([subjectId])
  @@map("quizzes")
}

model QuizAnswer {
  id                  String       @id @default(cuid())
  attemptId           String
  questionId          String
  selectedOptionIndex Int
  isCorrect           Boolean

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
  @@map("quiz_answers")
}

model QuizAttempt {
  id          String       @id @default(cuid())
  quizId      String
  studentId   String
  score       Float
  attemptDate DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@index([quizId])
  @@index([studentId])
  @@map("quiz_attempts")
}

model DiscussionReply {
  id           String     @id @default(cuid())
  discussionId String
  authorId     String
  content      String
  createdAt    DateTime   @default(now())

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([authorId])
  @@map("discussion_replies")
}

model Discussion {
  id        String            @id @default(cuid())
  subjectId String
  authorId  String
  title     String
  content   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  subject Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  author  User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies DiscussionReply[]

  @@index([subjectId])
  @@index([authorId])
  @@map("discussions")
}

// ==================== B5. Smart Timetable ====================

enum TimetableStatus {
  DRAFT
  PUBLISHED
}

model TimetableSlot {
  id           String    @id @default(cuid())
  timetableId  String
  day          String
  startTime    String
  endTime      String
  subjectId    String
  facultyId    String
  classroomId  String
  periodNumber Int

  timetable Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  subject   Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([timetableId])
  @@index([subjectId])
  @@index([facultyId])
  @@index([classroomId])
  @@map("timetable_slots")
}

model Timetable {
  id           String          @id @default(cuid())
  departmentId String
  semester     Int
  section      String
  academicYear String
  status       TimetableStatus
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  department Department      @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  slots      TimetableSlot[]

  @@index([departmentId])
  @@map("timetables")
}

model PeriodTemplate {
  id           String   @id @default(cuid())
  periodNumber Int      @unique
  startTime    String
  endTime      String
  isBreak      Boolean  @default(false)
  breakLabel   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("period_templates")
}

// ==================== B6. Placement ====================

model Company {
  id        String   @id @default(cuid())
  name      String
  website   String
  industry  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drives PlacementDrive[]

  @@map("companies")
}

enum PlacementDriveStatus {
  UPCOMING
  ONGOING
  CLOSED
}

model PlacementDrive {
  id                 String               @id @default(cuid())
  companyId          String
  packageOffered     Float
  eligibilityCGPA    Float
  allowedDepartments String[]
  driveDate          DateTime
  status             PlacementDriveStatus
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  applications Application[]

  @@index([companyId])
  @@map("placement_drives")
}

enum ApplicationStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  REJECTED
  SELECTED
}

model Application {
  id        String            @id @default(cuid())
  driveId   String
  studentId String
  status    ApplicationStatus
  appliedAt DateTime          @default(now())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  drive   PlacementDrive @relation(fields: [driveId], references: [id], onDelete: Cascade)
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  interview Interview?
  offer     Offer?

  @@index([driveId])
  @@index([studentId])
  @@map("applications")
}

model Resume {
  id        String   @id @default(cuid())
  studentId String   @unique
  fileUrl   String
  atsScore  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  aiAnalysis AIResumeAnalysis?

  @@map("resumes")
}

enum InterviewMode {
  ONLINE
  OFFLINE
}

model Interview {
  id            String        @id @default(cuid())
  applicationId String        @unique
  scheduledAt   DateTime
  mode          InterviewMode
  result        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

enum OfferStatus {
  RELEASED
  ACCEPTED
  DECLINED
}

model Offer {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  packageOffered Float
  status         OfferStatus
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("offers")
}

// ==================== B7. AI Module ====================

model AIChatHistory {
  id        String   @id @default(cuid())
  userId    String
  prompt    String
  response  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ai_chat_histories")
}

model AIResumeAnalysis {
  id          String   @id @default(cuid())
  resumeId    String   @unique
  score       Float
  suggestions String[]
  createdAt   DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("ai_resume_analyses")
}

// ==================== B8. Notifications ====================

enum NotificationType {
  ASSIGNMENT
  QUIZ
  PLACEMENT
  TIMETABLE
  ANNOUNCEMENT
  GENERAL
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  title          String
  message        String
  type           NotificationType
  isRead         Boolean          @default(false)
  batchId        String?
  audienceType   String?
  audienceTarget String?
  senderId       String?
  createdAt      DateTime         @default(now())

  user   User  @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  sender User? @relation("SentNotifications", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([batchId])
  @@map("notifications")
}

// ==================== B9. Placement Center Prep & DSA Bank ====================

enum DSADifficulty {
  EASY
  MEDIUM
  HARD
}

enum DSAPlatform {
  LEETCODE
  HACKERRANK
}

enum DSAProblemStatus {
  NOT_STARTED
  IN_PROGRESS
  SOLVED
}

model PlacementDomain {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentProfiles StudentPlacementProfile[]
  dsaProblems     DSAProblem[]

  @@map("placement_domains")
}

model StudentPlacementProfile {
  id                 String    @id @default(cuid())
  studentId          String    @unique
  domainId           String?
  roadmapGeneratedAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  domain  PlacementDomain? @relation(fields: [domainId], references: [id], onDelete: SetNull)

  roadmapStages RoadmapStage[]

  @@index([studentId])
  @@index([domainId])
  @@map("student_placement_profiles")
}

model RoadmapStage {
  id                        String   @id @default(cuid())
  studentPlacementProfileId String
  order                     Int
  title                     String
  description               String
  durationLabel             String
  isCompleted               Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  profile StudentPlacementProfile @relation(fields: [studentPlacementProfileId], references: [id], onDelete: Cascade)

  @@index([studentPlacementProfileId])
  @@map("roadmap_stages")
}

model DSAProblem {
  id                String        @id @default(cuid())
  title             String
  domainId          String
  difficulty        DSADifficulty
  platform          DSAPlatform
  problemUrl        String
  solutionVideoUrl  String?
  codeSolution      String?
  dryRunExplanation String?
  order             Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  domain PlacementDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  progressEntries StudentProblemProgress[]

  @@index([domainId])
  @@index([difficulty])
  @@map("dsa_problems")
}

model StudentProblemProgress {
  id        String           @id @default(cuid())
  studentId String
  problemId String
  status    DSAProblemStatus @default(NOT_STARTED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  problem DSAProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([studentId, problemId])
  @@index([studentId])
  @@index([problemId])
  @@map("student_problem_progress")
}
